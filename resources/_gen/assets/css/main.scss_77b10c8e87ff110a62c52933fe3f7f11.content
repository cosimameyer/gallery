acing:.03em;text-align:center;text-transform:uppercase;opacity:0;transition:opacity .2s ease;pointer-events:none;z-index:1}.gallery-item--bio:hover::after{opacity:1}.pswp__top-bar{background:linear-gradient(to bottom,rgba(0,0,0,.35) 0%,transparent 100%);height:72px;align-items:center;padding:0 8px}.pswp__button{width:40px!important;height:40px!important;border-radius:50%!important;background:rgba(255,255,255,.12)!important;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);margin:0 3px!important;transition:background .18s ease!important;opacity:1!important}.pswp__button:hover{background:rgba(255,255,255,.24)!important}.pswp__icn{top:4px!important;left:4px!important;width:32px!important;height:32px!important}.gallery-banner{width:100%;max-height:380px;overflow:hidden;margin-bottom:24px;border-radius:8px}.gallery-banner img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}.caption-name{display:block;font-family:var(--f-heading);font-size:1.1em;font-weight:700;margin-bottom:10px}.caption-bullets{list-style:disc;padding:0 0 0 1.1em;margin:0}.caption-bullets li{margin-bottom:6px;line-height:1.5}.caption-bullets li p{display:inline;margin:0}.pswp__dynamic-caption--aside{padding:32px 28px!important;max-width:340px;display:flex;flex-direction:column;justify-content:center}.pswp__dynamic-caption--aside .caption-name{font-size:1.55em;font-weight:700;letter-spacing:.02em;color:#fff;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.15);line-height:1.2}.pswp__dynamic-caption--aside .caption-bullets{flex:1}.pswp__dynamic-caption--aside .caption-bullets li{font-size:.9em;line-height:1.6;color:rgba(255,255,255,.8);margin-bottom:10px}.pswp__dynamic-caption--aside .caption-bullets li:last-child{margin-bottom:0;color:rgba(255,255,255,.65);font-size:.85em}.pswp__dynamic-caption--aside a{color:inherit;text-decoration:underline;text-underline-offset:2px;text-decoration-color:rgba(255,255,255,.45);transition:text-deco